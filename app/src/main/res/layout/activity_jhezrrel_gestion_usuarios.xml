<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_jhezrrel"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="34dp"
        android:paddingBottom="36dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnVolver"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_flecha_atras"
                    android:contentDescription="@string/jhez_regresar"
                    android:tint="@color/jhez_icono" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/jhez_gestion_usuarios"
                    android:textColor="@color/jhez_texto_principal"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

        <ImageView
            android:layout_width="120dp"
            android:layout_height="100dp"
            android:contentDescription="@string/logo_desc"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_jhezrrel" />



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/jhez_cuadro_borde"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="10dp">

                <TextView
                    android:id="@+id/tvTotalUsuarios"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00"
                    android:textColor="@color/jhez_texto_principal"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/jhez_total_usuarios"
                    android:textColor="@color/jhez_texto_principal"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/jhez_cuadro_borde"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="10dp">

                <TextView
                    android:id="@+id/tvTotalAceptados"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00"
                    android:textColor="@color/jhez_texto_principal"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/jhez_total_aceptados"
                    android:textColor="@color/jhez_texto_principal"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/jhez_campo_borde"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_buscar"
            android:tint="@color/jhez_icono" />

            <EditText
                android:id="@+id/etBuscarUsuario"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="@string/jhez_hint_buscar_usuario"
                android:inputType="text"
                android:paddingStart="12dp"
                android:textColor="@color/jhez_texto_principal"
                android:textColorHint="@color/jhez_texto_principal"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/listaUsuarios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:background="@drawable/jhez_cuadro_borde"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="26dp" />
    </LinearLayout>
</ScrollView>
