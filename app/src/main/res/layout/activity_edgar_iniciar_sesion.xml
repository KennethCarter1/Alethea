<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_edgar"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:paddingHorizontal="20dp">

    <!-- Logo -->
    <ImageView
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="center_horizontal"
        android:contentDescription="@string/logo_desc"
        android:src="@drawable/logo_edgar" />

    <!-- Iniciar Sesión titulo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        android:fontFamily="serif"
        android:text="@string/login_titulo"
        android:textColor="@color/edgar_texto_principal"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Campo Usuario -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/edgar_campo_borde"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_perfil"
            android:contentDescription="@string/login_usuario" />

        <EditText
            android:id="@+id/etUsuario"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="@string/login_usuario"
            android:textColorHint="@color/edgar_texto_secundario"
            android:textColor="@color/edgar_texto_principal"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:background="@android:color/transparent"
            android:paddingStart="10dp"
            android:inputType="text"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Campo Contraseña -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/edgar_campo_borde"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_candado"
            android:tint="@color/edgar_icono_campo"
            android:contentDescription="@string/login_contrasena" />

        <EditText
            android:id="@+id/etContrasena"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="@string/login_contrasena"
            android:textColorHint="@color/edgar_texto_secundario"
            android:textColor="@color/edgar_texto_principal"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:background="@android:color/transparent"
            android:paddingStart="10dp"
            android:inputType="textPassword"
            android:maxLines="1" />

        <ImageView
            android:id="@+id/ivOjoContrasena"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_visibilidad"
            android:tint="@color/edgar_icono_campo"
            android:contentDescription="@string/login_mostrar_contrasena"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Botón Iniciar Sesión -->
    <LinearLayout
        android:id="@+id/btnIniciarSesion"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:background="@drawable/edgar_boton_negro"
        android:layout_marginBottom="14dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_perfil"
            android:contentDescription="@string/login_boton" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_boton"
            android:textColor="@color/edgar_texto_boton"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Registrarse -->
    <TextView
        android:id="@+id/btnRegistrarse"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="sans-serif"
        android:text="@string/login_registrarse"
        android:textColor="@color/edgar_texto_principal"
        android:textSize="18sp" />

</LinearLayout>
