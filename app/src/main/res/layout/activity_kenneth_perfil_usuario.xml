<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_kenneth">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <ImageView
                android:id="@+id/btnAtras"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_flecha_atras"
                android:contentDescription="@string/ken_regresar"
                android:tint="@color/kenneth_icono" />

            <TextView
                android:id="@+id/tvTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_toEndOf="@id/btnAtras"
                android:layout_centerVertical="true"
                android:text="@string/ken_perfil"
                android:textColor="@color/kenneth_texto_principal"
                android:textSize="22sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Avatar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/kenneth_circulo_icono">

                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_perfil"
                    android:tint="@color/kenneth_icono"
                    android:contentDescription="" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvNombrePerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/kenneth_texto_principal"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/kenneth_cuadro"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/kenneth_circulo_icono">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_libro"
                        android:tint="@color/kenneth_icono"
                        android:contentDescription="@string/ken_desc_libros" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvTotalPrestamos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="00"
                    android:textColor="@color/kenneth_texto_principal"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ken_total_libros"
                    android:textColor="@color/kenneth_texto_principal"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="@color/kenneth_linea" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/kenneth_circulo_icono">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_corazon"
                        android:tint="@color/kenneth_icono"
                        android:contentDescription="@string/ken_desc_favoritos" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvTotalFavoritos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="00"
                    android:textColor="@color/kenneth_texto_principal"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ken_total_favoritos"
                    android:textColor="@color/kenneth_texto_principal"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="@color/kenneth_linea" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/kenneth_circulo_icono">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_reloj_arena"
                        android:tint="@color/kenneth_icono"
                        android:contentDescription="@string/ken_desc_espera" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvTotalPendientes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="00"
                    android:textColor="@color/kenneth_texto_principal"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ken_total_espera"
                    android:textColor="@color/kenneth_texto_principal"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- Personal Info -->
        <LinearLayout
            android:id="@+id/cardInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/kenneth_cuadro"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_perfil"
                android:drawableTint="@color/kenneth_icono_dorado"
                android:drawablePadding="6dp"
                android:text="@string/ken_informacion_personal"
                android:textColor="@color/kenneth_texto_principal"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/kenneth_campo"
                android:drawableStart="@drawable/ic_perfil"
                android:drawableTint="@color/kenneth_icono"
                android:drawablePadding="6dp"
                android:hint="Nombre"
                android:paddingHorizontal="8dp"
                android:textColor="@color/kenneth_texto_principal"
                android:textColorHint="@color/kenneth_texto_secundario"
                android:textSize="12sp"
                android:inputType="text" />

            <EditText
                android:id="@+id/etApellido"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/kenneth_campo"
                android:drawableStart="@drawable/ic_perfil"
                android:drawableTint="@color/kenneth_icono"
                android:drawablePadding="6dp"
                android:hint="Apellido"
                android:paddingHorizontal="8dp"
                android:textColor="@color/kenneth_texto_principal"
                android:textColorHint="@color/kenneth_texto_secundario"
                android:textSize="12sp"
                android:inputType="text" />

            <EditText
                android:id="@+id/etCorreo"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/kenneth_campo"
                android:drawableStart="@drawable/ic_correo"
                android:drawableTint="@color/kenneth_icono"
                android:drawablePadding="6dp"
                android:hint="Correo electrónico"
                android:paddingHorizontal="8dp"
                android:textColor="@color/kenneth_texto_principal"
                android:textColorHint="@color/kenneth_texto_secundario"
                android:textSize="12sp"
                android:inputType="textEmailAddress" />

            <EditText
                android:id="@+id/etCedula"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/kenneth_campo"
                android:drawableStart="@drawable/ic_cedula"
                android:drawableTint="@color/kenneth_icono"
                android:drawablePadding="6dp"
                android:hint="Cédula"
                android:paddingHorizontal="8dp"
                android:textColor="@color/kenneth_texto_principal"
                android:textColorHint="@color/kenneth_texto_secundario"
                android:textSize="12sp"
                android:inputType="text" />

            <Spinner
                android:id="@+id/spNacionalidad"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/kenneth_campo"
                android:paddingHorizontal="8dp" />

            <LinearLayout
                android:id="@+id/btnGuardarCambios"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/kenneth_boton_principal"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_lapiz"
                    android:tint="@color/kenneth_texto_boton"
                    android:contentDescription="" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/ken_guardar_cambios"
                    android:textColor="@color/kenneth_texto_boton"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Password Card -->
        <LinearLayout
            android:id="@+id/cardPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/kenneth_cuadro"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_candado"
                android:drawableTint="@color/kenneth_icono"
                android:drawablePadding="6dp"
                android:text="@string/ken_cambiar_contrasena"
                android:textColor="@color/kenneth_texto_principal"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/kenneth_campo"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="4dp">

                <EditText
                    android:id="@+id/etContrasenaActual"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:drawableStart="@drawable/ic_candado"
                    android:drawableTint="@color/kenneth_icono"
                    android:drawablePadding="6dp"
                    android:hint="Contraseña actual"
                    android:inputType="textPassword"
                    android:paddingHorizontal="4dp"
                    android:textColor="@color/kenneth_texto_principal"
                    android:textColorHint="@color/kenneth_texto_secundario"
                    android:textSize="12sp" />

                <ImageView
                    android:id="@+id/ivOjoActual"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_visibilidad"
                    android:tint="@color/kenneth_icono_ojo"
                    android:contentDescription="Mostrar contraseña"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/kenneth_campo"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="4dp">

                <EditText
                    android:id="@+id/etNuevaContrasena"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:drawableStart="@drawable/ic_candado"
                    android:drawableTint="@color/kenneth_icono"
                    android:drawablePadding="6dp"
                    android:hint="Nueva contraseña"
                    android:inputType="textPassword"
                    android:paddingHorizontal="4dp"
                    android:textColor="@color/kenneth_texto_principal"
                    android:textColorHint="@color/kenneth_texto_secundario"
                    android:textSize="12sp" />

                <ImageView
                    android:id="@+id/ivOjoNueva"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_visibilidad"
                    android:tint="@color/kenneth_icono_ojo"
                    android:contentDescription="Mostrar contraseña"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/kenneth_campo"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="4dp">

                <EditText
                    android:id="@+id/etConfirmarContrasena"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:drawableStart="@drawable/ic_candado"
                    android:drawableTint="@color/kenneth_icono"
                    android:drawablePadding="6dp"
                    android:hint="Confirmar contraseña"
                    android:inputType="textPassword"
                    android:paddingHorizontal="4dp"
                    android:textColor="@color/kenneth_texto_principal"
                    android:textColorHint="@color/kenneth_texto_secundario"
                    android:textSize="12sp" />

                <ImageView
                    android:id="@+id/ivOjoConfirmar"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_visibilidad"
                    android:tint="@color/kenneth_icono_ojo"
                    android:contentDescription="Mostrar contraseña"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnActualizarContrasena"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/kenneth_boton_principal"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_lapiz"
                    android:tint="@color/kenneth_texto_boton"
                    android:contentDescription="" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/ken_actualizar_contrasena"
                    android:textColor="@color/kenneth_texto_boton"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
