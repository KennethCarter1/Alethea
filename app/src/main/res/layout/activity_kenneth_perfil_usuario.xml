<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_claro">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".CarterKenneth.PerfilUsuarioActivity">

        <ImageView
            android:id="@+id/btnAtras"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_flecha_atras"
            android:contentDescription="@string/ken_regresar"
            android:tint="#5c3f1c"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/ken_perfil"
            android:textColor="#5c3f1c"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnAtras"
            app:layout_constraintStart_toEndOf="@id/btnAtras"
            app:layout_constraintTop_toTopOf="@id/btnAtras" />

        <LinearLayout
            android:id="@+id/cardEstadisticas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/cuadro_borde"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnAtras">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/circulo_estadistica">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_libro"
                        android:contentDescription="@string/ken_desc_libros" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="0"
                    android:textColor="#5c3f1c"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ken_total_libros"
                    android:textColor="#5c3f1c"
                    android:textSize="12sp"
                    android:gravity="center" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginVertical="8dp"
                android:background="#5c3f1c" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/circulo_estadistica">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_corazon"
                        android:contentDescription="@string/ken_desc_favoritos" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="0"
                    android:textColor="#5c3f1c"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ken_total_favoritos"
                    android:textColor="#5c3f1c"
                    android:textSize="12sp"
                    android:gravity="center" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginVertical="8dp"
                android:background="#5c3f1c" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/circulo_estadistica">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_reloj_arena"
                        android:contentDescription="@string/ken_desc_espera" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="0"
                    android:textColor="#5c3f1c"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ken_total_espera"
                    android:textColor="#5c3f1c"
                    android:textSize="12sp"
                    android:gravity="center" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/cuadro_borde"
            android:orientation="vertical"
            android:padding="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardEstadisticas">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/ken_informacion_personal"
                android:textColor="#5c3f1c"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ken_nombre"
                android:textColor="#5c3f1c"
                android:textSize="12sp" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/campo_borde"
                android:paddingHorizontal="8dp"
                android:textColor="#5c3f1c"
                android:textSize="13sp"
                android:inputType="text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ken_apellido"
                android:textColor="#5c3f1c"
                android:textSize="12sp" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/campo_borde"
                android:paddingHorizontal="8dp"
                android:textColor="#5c3f1c"
                android:textSize="13sp"
                android:inputType="text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ken_correo"
                android:textColor="#5c3f1c"
                android:textSize="12sp" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/campo_borde"
                android:paddingHorizontal="8dp"
                android:textColor="#5c3f1c"
                android:textSize="13sp"
                android:inputType="textEmailAddress" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ken_cedula"
                android:textColor="#5c3f1c"
                android:textSize="12sp" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/campo_borde"
                android:paddingHorizontal="8dp"
                android:textColor="#5c3f1c"
                android:textSize="13sp"
                android:inputType="number" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ken_nacionalidad"
                android:textColor="#5c3f1c"
                android:textSize="12sp" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:background="@drawable/campo_borde"
                android:paddingHorizontal="8dp"
                android:textColor="#5c3f1c"
                android:textSize="13sp"
                android:inputType="text" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/boton_guardar"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ken_guardar_cambios"
                    android:textColor="#f6eacc"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardPassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/cuadro_borde"
            android:orientation="vertical"
            android:padding="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardInfo">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/ken_cambiar_contrasena"
                android:textColor="#5c3f1c"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ken_contrasena_actual"
                android:textColor="#5c3f1c"
                android:textSize="12sp" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/campo_borde"
                android:paddingHorizontal="8dp"
                android:textColor="#5c3f1c"
                android:textSize="13sp"
                android:inputType="textPassword" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ken_nueva_contrasena"
                android:textColor="#5c3f1c"
                android:textSize="12sp" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/campo_borde"
                android:paddingHorizontal="8dp"
                android:textColor="#5c3f1c"
                android:textSize="13sp"
                android:inputType="textPassword" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ken_confirmar_contrasena"
                android:textColor="#5c3f1c"
                android:textSize="12sp" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:background="@drawable/campo_borde"
                android:paddingHorizontal="8dp"
                android:textColor="#5c3f1c"
                android:textSize="13sp"
                android:inputType="textPassword" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/boton_guardar"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ken_actualizar_contrasena"
                    android:textColor="#f6eacc"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
