<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_rachel"
    tools:context=".MejiaRachel.EditarLibroActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="160dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/btnAtras"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical"
                android:src="@drawable/ic_flecha_atras"
                android:contentDescription="@string/rachel_regresar"
                android:tint="@color/rachel_texto_encabezado" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:text="@string/editar_libro_titulo"
                android:textColor="@color/rachel_texto_encabezado"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Card formulario -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/rachel_tarjeta"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Nombre del libro -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="@string/editar_libro_nombre"
                android:textColor="@color/rachel_texto_formulario"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etNombreLibro"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/rachel_campo"
                android:fontFamily="sans-serif"
                android:hint="@string/editar_libro_nombre_hint"
                android:paddingHorizontal="12dp"
                android:textColor="@color/rachel_texto_formulario"
                android:textColorHint="@color/rachel_texto_secundario"
                android:textSize="14sp" />

            <!-- Autor del libro -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="@string/editar_libro_autor"
                android:textColor="@color/rachel_texto_formulario"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etAutorLibro"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/rachel_campo"
                android:fontFamily="sans-serif"
                android:hint="@string/editar_libro_autor_hint"
                android:paddingHorizontal="12dp"
                android:textColor="@color/rachel_texto_formulario"
                android:textColorHint="@color/rachel_texto_secundario"
                android:textSize="14sp" />

            <!-- Categoria + Año (en fila) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="@string/editar_libro_categoria"
                        android:textColor="@color/rachel_texto_formulario"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/rachel_campo"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp">

                        <TextView
                            android:id="@+id/tvCategoria"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/editar_libro_categoria_hint"
                            android:textColor="@color/rachel_texto_secundario"
                            android:textSize="13sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@string/editar_libro_categoria"
                            android:src="@drawable/ic_chevron_down"
                            android:tint="@color/rachel_icono_marron" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="@string/editar_libro_anio"
                        android:textColor="@color/rachel_texto_formulario"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/rachel_campo"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp">

                        <EditText
                            android:id="@+id/etAnioCreado"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:hint="@string/editar_libro_anio_hint"
                            android:inputType="number"
                            android:maxLines="1"
                            android:textColor="@color/rachel_texto_formulario"
                            android:textColorHint="@color/rachel_texto_secundario"
                            android:textSize="13sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@string/editar_libro_anio"
                            android:src="@drawable/ic_calendario"
                            android:tint="@color/rachel_icono_marron" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="@string/editar_libro_stock"
                android:textColor="@color/rachel_texto_formulario"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etStock"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/rachel_campo"
                android:hint="@string/editar_libro_stock_hint"
                android:inputType="number"
                android:maxLines="1"
                android:paddingHorizontal="12dp"
                android:textColor="@color/rachel_texto_formulario"
                android:textColorHint="@color/rachel_texto_secundario"
                android:textSize="14sp" />

            <!-- Sinopsis -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="@string/editar_libro_sinopsis"
                android:textColor="@color/rachel_texto_formulario"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etSinopsis"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:background="@drawable/rachel_campo"
                android:fontFamily="sans-serif"
                android:gravity="top"
                android:hint="@string/editar_libro_sinopsis_hint"
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textColor="@color/rachel_texto_formulario"
                android:textColorHint="@color/rachel_texto_secundario"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Campo imagen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/rachel_campo"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/tvImagenLibro"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/editar_libro_imagen_hint"
                android:textColor="@color/rachel_texto_secundario"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/editar_libro_imagen_hint"
                android:src="@drawable/ic_imagen"
                android:tint="@color/rachel_icono_marron" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivPreviewImagen"
            android:layout_width="120dp"
            android:layout_height="160dp"
            android:layout_marginBottom="20dp"
            android:layout_gravity="center_horizontal"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/btnCancelar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/rachel_boton_secundario"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/accion_cancelar"
                    android:textColor="@color/rachel_texto_principal"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnEditarLibro"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/rachel_boton_principal"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/editar_libro_titulo"
                    android:textColor="@color/rachel_texto_boton"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
