<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_claro"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="34dp"
        android:paddingBottom="42dp">

        <TextView
            android:id="@+id/btnVolver"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:text="&lt;"
            android:textColor="#6F471B"
            android:textSize="52sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="190dp"
            android:layout_height="150dp"
            android:contentDescription="@string/logo_desc"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_claro" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif"
            android:text="Agregar Libro"
            android:textColor="#5A4430"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:background="@drawable/panel_blanco"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre del libro"
                android:textColor="#7A6A5A"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etNombreLibro"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/campo_borde"
                android:hint="Ingrese el Nombre del libro..."
                android:inputType="textCapWords"
                android:paddingHorizontal="10dp"
                android:textColor="#5A4430"
                android:textColorHint="#9C8E80"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Autor del libro"
                android:textColor="#7A6A5A"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etAutorLibro"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/campo_borde"
                android:hint="Ingrese el Autor del libro..."
                android:inputType="textCapWords"
                android:paddingHorizontal="10dp"
                android:textColor="#5A4430"
                android:textColorHint="#9C8E80"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Categoria"
                        android:textColor="#7A6A5A"
                        android:textSize="14sp" />

                    <Spinner
                        android:id="@+id/spCategoria"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/campo_borde" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ano creado"
                        android:textColor="#7A6A5A"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etAnio"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/campo_borde"
                        android:hint="Ingrese el ano"
                        android:inputType="number"
                        android:maxLength="4"
                        android:paddingHorizontal="10dp"
                        android:textColor="#5A4430"
                        android:textColorHint="#9C8E80"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Sinopsis"
                android:textColor="#7A6A5A"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etSinopsis"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/campo_borde"
                android:gravity="top"
                android:hint="Escriba la sinopsis del libro"
                android:inputType="textMultiLine"
                android:padding="10dp"
                android:textColor="#5A4430"
                android:textColorHint="#9C8E80"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvImagen"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/panel_blanco"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:text="Ingrese la imagen                                      [ ]"
            android:textColor="#8A7866"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnCancelar"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginEnd="20dp"
                android:layout_weight="1"
                android:background="@drawable/boton_claro_borde"
                android:text="Cancelar"
                android:textAllCaps="false"
                android:textColor="#5A4430"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:background="@drawable/boton_cafe"
                android:text="Guardar Libro"
                android:textAllCaps="false"
                android:textColor="@color/blanco"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
