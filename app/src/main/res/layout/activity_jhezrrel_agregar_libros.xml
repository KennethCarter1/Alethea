<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_claro"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="34dp"
        android:paddingBottom="42dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnVolver"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_flecha_atras"
                android:contentDescription="@string/jhez_regresar"
                android:tint="#5c3f1c" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/jhez_agregar_libro"
                android:textColor="#5c3f1c"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:layout_width="190dp"
            android:layout_height="150dp"
            android:contentDescription="@string/logo_desc"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_claro" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:background="@drawable/cuadro_borde"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/jhez_nombre_libro"
                android:textColor="#5c3f1c"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/jhez_autor_libro"
                android:textColor="#5c3f1c"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etAutorLibro"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/campo_borde"
                android:hint="@string/jhez_hint_autor"
                android:inputType="textCapWords"
                android:paddingHorizontal="10dp"
                android:textColor="#5c3f1c"
                android:textColorHint="#5c3f1c"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/jhez_categoria"
                        android:textColor="#5c3f1c"
                        android:textSize="14sp" />

                    <Spinner
                        android:id="@+id/spCategoria"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/campo_borde" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/jhez_anio_creado"
                        android:textColor="#5c3f1c"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etAnio"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/campo_borde"
                        android:hint="@string/jhez_hint_anio"
                        android:inputType="number"
                        android:maxLength="4"
                        android:paddingHorizontal="10dp"
                        android:textColor="#5c3f1c"
                        android:textColorHint="#5c3f1c"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <EditText
                android:id="@+id/etNombreLibro"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/campo_borde"
                android:hint="@string/jhez_hint_nombre"
                android:inputType="textCapWords"
                android:paddingHorizontal="10dp"
                android:textColor="#5c3f1c"
                android:textColorHint="#5c3f1c"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/jhez_sinopsis"
                android:textColor="#5c3f1c"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etSinopsis"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/campo_borde"
                android:gravity="top"
                android:hint="@string/jhez_hint_sinopsis"
                android:inputType="textMultiLine"
                android:padding="10dp"
                android:textColor="#5c3f1c"
                android:textColorHint="#5c3f1c"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvImagen"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/cuadro_borde"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:text="@string/jhez_ingrese_imagen"
            android:textColor="#5c3f1c"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:id="@+id/btnCancelar"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginEnd="20dp"
                android:layout_weight="1"
                android:background="@drawable/boton_claro_borde"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/jhez_cancelar"
                    android:textColor="#5c3f1c"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnGuardar"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:background="@drawable/boton_cafe"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/jhez_guardar_libro"
                    android:textColor="#f6eacc"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
