<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/rachel_cuadro"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Usuario -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_perfil"
            android:contentDescription="@string/tabla_usuario"
            android:tint="@color/rachel_texto_principal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/tabla_usuario"
            android:textColor="@color/rachel_texto_principal"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvUsuario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="@string/item_usuario_placeholder"
            android:textColor="@color/rachel_texto_principal"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Libro -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_libro"
            android:contentDescription="@string/tabla_libro"
            android:tint="@color/rachel_texto_principal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/tabla_libro"
            android:textColor="@color/rachel_texto_principal"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLibro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="@string/item_libro_placeholder"
            android:textColor="@color/rachel_texto_principal"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Fecha Solicitada -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_calendario"
            android:contentDescription="@string/tabla_fecha_solicitada"
            android:tint="@color/rachel_texto_principal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/tabla_fecha_solicitada"
            android:textColor="@color/rachel_texto_principal"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFechaSolicitada"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="@string/item_fecha_placeholder"
            android:textColor="@color/rachel_texto_principal"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvStockPendiente"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/estado_sin_stock"
        android:textColor="@color/rachel_texto_principal"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- Botones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <LinearLayout
            android:id="@+id/btnAceptar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_btn_aceptar"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_corazon"
                android:contentDescription="@string/accion_aceptar"
                android:tint="@color/rachel_texto_estado_claro" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/accion_aceptar"
                android:textColor="@color/rachel_texto_estado_claro"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnRechazar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_rechazar"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_eliminar"
                android:contentDescription="@string/accion_rechazar"
                android:tint="@color/rachel_texto_estado_claro" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/accion_rechazar"
                android:textColor="@color/rachel_texto_estado_claro"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
