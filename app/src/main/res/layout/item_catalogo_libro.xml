<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/kenneth_tarjeta"
    android:orientation="horizontal"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTituloLibro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/kenneth_texto_item"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAutorLibro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/kenneth_texto_item"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvCategoriaLibro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/kenneth_texto_secundario"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvAnioLibro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/kenneth_texto_secundario"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvStockCatalogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/ken_disponibles_muestra"
            android:textColor="@color/kenneth_texto_item"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/btnFav"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center_vertical"
        android:background="@drawable/kenneth_circulo_icono">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:contentDescription="@string/ken_desc_favoritos"
            android:src="@drawable/ic_marcador"
            android:tint="@color/kenneth_icono" />
    </FrameLayout>
</LinearLayout>
