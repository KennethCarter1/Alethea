<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/jhez_cuadro_borde"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/jhez_circulo_icono">

        <ImageView
            android:id="@+id/ivIcono"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:contentDescription="Usuario"
            android:src="@drawable/ic_perfil" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre"
            android:textColor="@color/jhez_texto_principal"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCorreo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="correo@ejemplo.com"
            android:textColor="@color/jhez_texto_secundario"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvCedula"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="000-0000000-0"
            android:textColor="@color/jhez_texto_secundario"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvRol"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/jhez_badge_outline"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="Usuario"
        android:textColor="@color/jhez_texto_principal"
        android:textSize="11sp"
        android:textStyle="bold" />
</LinearLayout>
