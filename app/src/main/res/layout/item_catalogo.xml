<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/kenneth_cuadro"
    android:orientation="horizontal"
    android:padding="8dp">

    <ImageView
        android:id="@+id/ivPortadaCat"
        android:layout_width="60dp"
        android:layout_height="85dp"
        android:scaleType="centerCrop"
        android:src="@drawable/logo_kenneth"
        android:contentDescription="" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTituloCat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/kenneth_texto_principal"
                android:textSize="13sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/btnFavCat"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/kenneth_circulo_icono">

                <ImageView
                    android:id="@+id/ivFavCat"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_corazon"
                    android:tint="@color/kenneth_icono"
                    android:contentDescription="" />
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvAutorCat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/kenneth_texto_principal"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvCategoriaCat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:textColor="@color/kenneth_texto_principal"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvAnioCat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/kenneth_texto_principal"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvStockCat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/ken_disponibles_muestra"
            android:textColor="@color/kenneth_texto_principal"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
