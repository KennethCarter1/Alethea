<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/rachel_cuadro"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <FrameLayout
        android:id="@+id/iconContainer"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/rachel_circulo_icono">

        <ImageView
            android:id="@+id/ivIcono"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:contentDescription="@string/reporte_categoria_ejemplo"
            android:src="@drawable/ic_libros_pila"
            android:tint="@color/rachel_icono_marron" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvCategoria"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:text="@string/reporte_categoria_ejemplo"
        android:textColor="@color/rachel_texto_principal"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvCantidad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/rachel_badge_outline"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:text="@string/valor_cero"
        android:textColor="@color/rachel_texto_principal"
        android:textSize="13sp"
        android:textStyle="bold" />
</LinearLayout>
