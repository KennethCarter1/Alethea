<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/rachel_tarjeta"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <ImageView
        android:id="@+id/ivPortada"
        android:layout_width="76dp"
        android:layout_height="112dp"
        android:background="@color/rachel_fondo_portada"
        android:contentDescription="@string/gestion_libros_listado"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNombreLibro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:breakStrategy="balanced"
            android:text="@string/item_libro_nombre_placeholder"
            android:textColor="@color/rachel_texto_formulario"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAutorLibro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="6dp"
            android:text="@string/item_libro_autor_placeholder"
            android:textColor="@color/rachel_texto_formulario"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvCategoriaLibro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/item_libro_categoria_placeholder"
            android:textColor="@color/rachel_texto_secundario"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvAnioLibro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/item_libro_anio_placeholder"
            android:textColor="@color/rachel_texto_secundario"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvStockLibro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:maxLines="2"
            android:text="@string/item_libro_stock_placeholder"
            android:textColor="@color/rachel_texto_principal"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/btnEditarItem"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/rachel_circulo_icono">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="@string/accion_editar"
                android:src="@drawable/ic_editar"
                android:tint="@color/rachel_icono_marron" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnEliminarItem"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/rachel_circulo_icono">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="@string/accion_eliminar"
                android:src="@drawable/ic_eliminar"
                android:tint="@color/rachel_icono_marron" />
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
