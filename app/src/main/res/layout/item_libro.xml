<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:orientation="horizontal"
    android:padding="12dp">

    <ImageView
        android:id="@+id/ivPortada"
        android:layout_width="70dp"
        android:layout_height="90dp"
        android:background="@color/gris_claro"
        android:contentDescription="@string/gestion_libros_listado"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNombreLibro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/item_libro_nombre_placeholder"
            android:textColor="@color/negro_suave"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAutorLibro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/item_libro_autor_placeholder"
            android:textColor="@color/negro_suave"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvCategoriaLibro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/item_libro_categoria_placeholder"
            android:textColor="@color/gris_medio"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvAnioLibro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/item_libro_anio_placeholder"
            android:textColor="@color/gris_medio"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/btnEditarItem"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_circulo_icono">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="@string/accion_editar"
                android:src="@drawable/ic_editar" />
        </FrameLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <FrameLayout
            android:id="@+id/btnEliminarItem"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_circulo_icono">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="@string/accion_eliminar"
                android:src="@drawable/ic_eliminar" />
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
